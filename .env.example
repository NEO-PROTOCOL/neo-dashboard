# NEO Dashboard - Environment Variables
# Repository: https://github.com/NEO-PROTOCOL/neo-dashboard

# Runtime
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
# Set to 1 (or "loopback") when behind a reverse proxy (Railway, Nginx, etc.)
TRUST_PROXY=1

# Security (required in production)
# UI sends this value to /api/* as header x-gateway-password.
# API_PASS_KEY is NOT an env var. It is a browser localStorage key:
# localStorage["neo_gateway_password"].
GATEWAY_PASSWORD=
# Backward-compat alias used by server.js
CLAWDBOT_GATEWAY_PASSWORD=

# IP auto-ban: after AUTH_BAN_THRESHOLD failures within AUTH_WINDOW_MS,
# the IP is silently blocked for AUTH_BAN_DURATION_MS (returns 429).
AUTH_BAN_THRESHOLD=10
AUTH_WINDOW_MS=300000
AUTH_BAN_DURATION_MS=3600000

# CORS: comma-separated list of allowed origins for cross-origin API access.
# Leave empty to allow only same-origin requests (recommended for production).
# Example: https://dashboard.neoprotocol.space,https://app.neoprotocol.space
CORS_ORIGIN=

# Upstream APIs
NEXUS_API_URL=https://neo-nexus-production.up.railway.app
NEXUS_ECOSYSTEM_URL=https://nexus.neoprotocol.space/api/ecosystem
NEOBOT_API_URL=https://nexus.neoprotocol.space
NEOBOT_API_KEY=
# Override the remote ecosystem source URL (used by sync + live probe)
ECOSYSTEM_SOURCE_URL=

# AI
ANTHROPIC_API_KEY=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring / live graph tuning
MONITOR_FETCH_TIMEOUT_MS=5000
ECOSYSTEM_NODE_PROBE_TIMEOUT_MS=2500
ECOSYSTEM_PROBE_CACHE_TTL_MS=12000

# Stack report
STACK_REPORT_SOURCE_URL=
STACK_REPORT_CACHE_TTL_MS=300000

# Ecosystem source override (local path — Railway ignores, useful for local dev)
ECOSYSTEM_JSON_PATH=
